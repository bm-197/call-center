# Production env vars consumed by docker-compose.prod.yml.
# Copy to .env.production and fill before running:
#   cp .env.production.example .env.production
#   $EDITOR .env.production
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build

# ─── VPS public address ────────────────────────────────────────────────────
# IPv4 of the VPS. Used by Asterisk for SIP/RTP NAT traversal and by
# Better Auth as the public callback host. If you have a domain pointed at
# the VPS, you can use it for FRONTEND_URL/BETTER_AUTH_URL but Asterisk
# still needs the IP.
ASTERISK_PUBLIC_IP=203.0.113.10
FRONTEND_URL=http://203.0.113.10:3000
BETTER_AUTH_URL=http://203.0.113.10:3000

# ─── Postgres ──────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=          # required — generate: openssl rand -base64 24
POSTGRES_DB=callcenter

# ─── Better Auth ───────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

# ─── Asterisk ARI + softphone secrets ──────────────────────────────────────
# Generate each: openssl rand -hex 16
# Public-facing SIP gets scanned by sipvicious within hours; strong unique
# passwords are NOT optional.
ARI_USERNAME=callcenter
ARI_PASSWORD=
ARI_APP_NAME=call-center
EXT_1001_PASSWORD=
EXT_1002_PASSWORD=
EXT_2001_PASSWORD=
HANDOFF_HUMAN_ENDPOINT=PJSIP/2001
HANDOFF_HUMAN_DIAL_TIMEOUT_SECONDS=30

# ─── AI providers ──────────────────────────────────────────────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=
# Path inside the api container if you mount Google credentials.
# GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/google-creds.json

# ─── Cloudflare R2 ─────────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_BUCKET_RECORDINGS=call-recordings
R2_BUCKET_KB_UPLOADS=kb-uploads

# ─── Resend (transactional email / org invitations) ───────────────────────
# Optional: leave empty to log invitation emails to the api logs instead of
# sending them. Useful for first-boot smoke tests.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=Call Center
