generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// ─── Auth (Better Auth manages these, but we define them for relations) ───

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions Session[]
  accounts Account[]
  members  Member[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String    @id @default(cuid())
  userId            String
  accountId         String
  providerId        String
  accessToken       String?
  refreshToken      String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope             String?
  idToken           String?
  password          String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Organization (Better Auth org plugin) ───

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members          Member[]
  agents           Agent[]
  calls            Call[]
  contacts         Contact[]
  knowledgeSources KnowledgeSource[]
  phoneNumbers     PhoneNumber[]
  invitations      Invitation[]
}

model Member {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           String   @default("agent") // owner, admin, agent, viewer
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

model Invitation {
  id             String   @id @default(cuid())
  email          String
  organizationId String
  role           String   @default("agent")
  inviterId      String
  status         String   @default("pending") // pending, accepted, expired
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ─── AI Agents ───

model Agent {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  language       String   @default("am") // am, en, am+en
  status         String   @default("draft") // draft, active, paused

  // AI Configuration
  systemPrompt String @default("")
  llmProvider  String @default("openai") // openai, google
  llmModel     String @default("gpt-4o")

  // Speech Configuration
  sttProvider String @default("google") // google, whisper
  ttsProvider String @default("google") // google
  ttsVoice    String @default("am-ET-Wavenet-A")

  // Handoff Configuration
  handoffEnabled         Boolean @default(true)
  handoffConfidenceThreshold Float @default(0.3)
  handoffMaxFailedAttempts   Int   @default(3)
  handoffMessage         String  @default("እባክዎ ይጠብቁ፣ ወደ ወኪላችን እያስተላለፍዎት ነው።")

  // Workflow (nodes + edges for orchestration canvas)
  workflow Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  calls            Call[]
  knowledgeSources KnowledgeSource[]
  phoneNumbers     PhoneNumber[]
}

// ─── Calls ───

model Call {
  id             String   @id @default(cuid())
  organizationId String
  agentId        String
  contactId      String?

  // Call details
  direction    String // inbound, outbound
  callerNumber String
  calleeNumber String
  status       String @default("ringing") // ringing, in_progress, ai_handling, queued, human_handling, completed, failed, missed
  duration     Int?   // seconds

  // Handoff
  handedOff       Boolean  @default(false)
  handoffReason   String?
  humanAgentId    String?  // Member ID of human who picked up
  handoffTime     DateTime?

  // Recordings & Transcripts
  recordingUrl    String?
  recordingDuration Int?
  transcriptAm    Json?    // Array of {speaker, text, timestamp}
  transcriptEn    Json?    // Auto-translated English version
  summary         String?
  summaryEn       String?
  sentiment       Float?   // -1 to 1

  // Metadata
  collectedInfo Json?   // Key-value data collected during call
  creditsUsed   Float   @default(0)

  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agent        Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
}

// ─── Contacts ───

model Contact {
  id             String   @id @default(cuid())
  organizationId String
  firstName      String?
  lastName       String?
  email          String?
  phoneNumber    String
  countryCode    String   @default("+251")
  notes          String?
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  calls        Call[]

  @@unique([organizationId, phoneNumber])
}

// ─── Knowledge Base ───

model KnowledgeSource {
  id             String   @id @default(cuid())
  organizationId String
  agentId        String?
  name           String
  description    String?
  language       String   @default("am") // am, en
  sourceType     String   // file, url, text, faq
  sourceUrl      String?  // for url type
  sourceContent  String?  // for text/faq type
  fileUrl        String?  // R2/MinIO URL for uploaded files
  fileName       String?
  fileSize       Int?

  // Processing status
  status      String @default("pending") // pending, processing, completed, failed
  errorMessage String?
  chunkCount  Int    @default(0)
  tokenCount  Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agent        Agent?           @relation(fields: [agentId], references: [id], onDelete: SetNull)
  chunks       KnowledgeChunk[]
}

model KnowledgeChunk {
  id       String @id @default(cuid())
  sourceId String
  content  String
  metadata Json?  // page number, section, etc.

  // pgvector — 1024 dimensions for multilingual-e5-large
  embedding Unsupported("vector(1024)")?

  createdAt DateTime @default(now())

  source KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId])
}

// ─── Phone Numbers ───

model PhoneNumber {
  id             String   @id @default(cuid())
  organizationId String
  agentId        String?
  number         String   @unique // +251...
  friendlyName   String?
  provider       String   @default("ethiotelecom") // ethiotelecom, twilio
  capabilities   Json?    // {voice: true, sms: true}
  status         String   @default("active") // active, inactive

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agent        Agent?       @relation(fields: [agentId], references: [id], onDelete: SetNull)
}
