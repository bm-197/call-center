{
  "name": "call-center-storage",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": ["nodejs_compat_v2"],
  "r2_buckets": [
    {
      "binding": "RECORDINGS",
      "bucket_name": "call-recordings"
    },
    {
      "binding": "UPLOADS",
      "bucket_name": "kb-uploads"
    }
  ]
}
