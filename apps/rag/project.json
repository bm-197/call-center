{
  "name": "rag",
  "sourceRoot": "apps/rag",
  "projectType": "application",
  "tags": ["scope:api", "type:app"],
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run uvicorn api:app --host 0.0.0.0 --port 4003 --reload",
        "cwd": "apps/rag"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run pytest -q || rc=$?; [ \"$rc\" = 5 ] && exit 0 || exit ${rc:-0}",
        "cwd": "apps/rag"
      }
    }
  }
}
